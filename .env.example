# Brainstew MCP Server — API Keys (fallback)
#
# OAuth is the preferred auth method — use brainstew_login tool instead:
#   brainstew_login("google-antigravity") — zero-setup Google Gemini OAuth (recommended)
#   brainstew_login("openai")             — ChatGPT Plus/Pro subscription OAuth
#   brainstew_login("google")             — standard Google OAuth (requires GOOGLE_OAUTH_CLIENT_ID)
#
# These env vars are only used if no OAuth token exists for a provider.
# Copy to .env and fill in your keys.

# OpenAI (for GPT) — https://platform.openai.com/api-keys
# Not needed if using ChatGPT subscription OAuth via brainstew_login("openai")
OPENAI_API_KEY=sk-...

# Google Gemini — https://aistudio.google.com/apikey
# Not needed if using Antigravity OAuth via brainstew_login("google-antigravity")
GEMINI_API_KEY=...

# xAI / Grok — https://console.x.ai
# xAI does not support OAuth — API key required
XAI_API_KEY=xai-...
