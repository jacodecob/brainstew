# Brainstew MCP Server — API Keys (fallback)
# OAuth is the preferred auth method — use brainstew_login tool instead.
# These env vars are only used if no OAuth token exists for a provider.
# Copy to .env and fill in your keys.

# OpenAI (for GPT-4o) — https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-...

# Google Gemini — https://aistudio.google.com/apikey
GEMINI_API_KEY=...

# xAI / Grok — https://console.x.ai
XAI_API_KEY=xai-...
